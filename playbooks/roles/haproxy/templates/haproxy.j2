{# Upstream стратегия #}
{% set _upstream_group = haproxy_traefik_upstream_group | default('traefik') %}
{% set _traefik_nodes = (groups[_upstream_group] | default([])) %}
{% set _has_traefik = (_traefik_nodes | length) > 0 %}
{% set _mode = (haproxy_upstream_mode | default('auto')) %}
{% set _swarm_nodes_count = (groups['swarm_managers'] | default([]) | length) + (groups['swarm_workers'] | default([]) | length) %}
{% set _swarm_ready = _swarm_nodes_count > 0 %}
{% set _traefik_method = traefik_deploy_method | default('auto') %}
{% set _compose_expected = (_traefik_method == 'compose') or ((_traefik_method == 'auto') and (not _swarm_ready)) %}
{% set _traefik_ready = _swarm_ready or _compose_expected %}
{% set _route_to_traefik = (_traefik_ready and _has_traefik) and ((_mode == 'traefik') or (_mode == 'auto')) %}
{% set _app_mode = haproxy_app_upstream_mode | default('traefik') %}
{% set _app_upstream_group = haproxy_app_upstream_group | default('swarm_managers') %}
{% set _app_upstream_nodes = (groups[_app_upstream_group] | default([])) %}
{% set _app_use_slot_upstream_host = haproxy_app_use_slot_upstream_host | default(false) | bool %}
{% set _app_sites = (cert_manager_certs_effective | default([]) | selectattr('upstream_port', 'defined') | rejectattr('cert_name', 'match', '^gitlab\\.') | rejectattr('cert_name', 'match', '^nexus\\.') | list) %}
{% set _route_apps_direct = (_app_mode == 'swarm_managers') and (_app_sites | length > 0) and ((_app_upstream_nodes | length > 0) or _app_use_slot_upstream_host) %}

global
  maxconn 50000
  maxpipes 50000
  tune.maxaccept 500
{% if (haproxy_tune_bufsize | default(0) | int) > 0 %}
  tune.bufsize {{ haproxy_tune_bufsize | int }}
{% endif %}
{% if (haproxy_tune_maxrewrite | default(0) | int) > 0 %}
  tune.maxrewrite {{ haproxy_tune_maxrewrite | int }}
{% endif %}
  log /dev/log    local0 info
  log /dev/log    local1 notice
  chroot /var/lib/haproxy
  stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
  stats timeout 30s
  user haproxy
  group haproxy
  daemon

  # Default SSL material locations
  ca-base /etc/ssl/certs
  crt-base /etc/ssl/private

  # Default ciphers to use on SSL-enabled listening sockets.
  ssl-default-bind-ciphers ECDH+AESGCM:DH+AESGCM:ECDH+AES256:DH+AES256:ECDH+AES128:DH+AES:RSA+AESGCM:RSA+AES:!aNULL:!MD5:!DSS
  ssl-default-bind-options no-sslv3

defaults
  log global
  mode http
  option dontlognull
  option forwardfor
  option httplog

  timeout connect 5000
  timeout client  50000
  timeout server  50000

  errorfile 400 /etc/haproxy/errors/400.http
  errorfile 403 /etc/haproxy/errors/403.http
  errorfile 408 /etc/haproxy/errors/408.http
  errorfile 500 /etc/haproxy/errors/500.http
  errorfile 502 /etc/haproxy/errors/502.http
  errorfile 503 /etc/haproxy/errors/503.http
  errorfile 504 /etc/haproxy/errors/504.http

  stats enable
  stats hide-version
  stats refresh 30s
  stats show-node
  stats uri /stats
  stats realm Haproxy\ Statistics
  stats auth {{haproxy_stats_user}}:{{haproxy_stats_password}}

{# Прямые L7-бэкенды до GitLab и Nexus (адреса из cert_manager: cert_name gitlab.* / nexus.*) #}

backend gitlab_https_tcp
  mode http
{% if haproxy_gitlab_upstream_configured | default(false) | bool %}
  balance source
  option httpchk GET /users/sign_in
  server gitlab_https_1 {{ haproxy_gitlab_https_upstream_host }}:{{ haproxy_gitlab_https_upstream_port }} check inter 3s fall 3 rise 2{% if haproxy_gitlab_https_server_ssl | default(true) | bool %} ssl verify none{% endif %}
{% else %}
  http-request return status 503 content-type text/plain string "Add cert_manager site cert_name gitlab.<domain> with upstream_host/upstream_port\n"
{% endif %}

{# backend gitlab_ssh_tcp только при настроенном GitLab в cert_manager; иначе HAProxy 2.8 не принимает tcp-request в backend #}
{% if haproxy_gitlab_upstream_configured | default(false) | bool %}
backend gitlab_ssh_tcp
  mode tcp
  balance source
  option tcp-check
  option log-health-checks
  server gitlab_ssh_1 {{ haproxy_gitlab_ssh_upstream_host }}:{{ haproxy_gitlab_ssh_upstream_port }} check
{% endif %}

backend nexus_websecure_tcp
  mode http
{% if haproxy_nexus_upstream_configured | default(false) | bool %}
  balance source
  option httpchk GET /
  server nexus_websecure_1 {{ haproxy_nexus_upstream_host }}:{{ haproxy_nexus_websecure_upstream_port }} check
{% else %}
  http-request return status 503 content-type text/plain string "Add cert_manager site cert_name nexus.<domain> with upstream_host and ports\n"
{% endif %}

backend nexus_docker_hosted_tcp
  mode http
{% if haproxy_nexus_upstream_configured | default(false) | bool %}
  balance source
  option httplog
  server nexus_docker_hosted_1 {{ haproxy_nexus_upstream_host }}:{{ haproxy_nexus_docker_hosted_upstream_port }} check
{% else %}
  http-request return status 503 content-type text/plain string "Nexus upstream not configured in cert_manager\n"
{% endif %}

backend nexus_docker_proxy_tcp
  mode http
{% if haproxy_nexus_upstream_configured | default(false) | bool %}
  balance source
  option httplog
  server nexus_docker_proxy_1 {{ haproxy_nexus_upstream_host }}:{{ haproxy_nexus_docker_proxy_upstream_port }} check
{% else %}
  http-request return status 503 content-type text/plain string "Nexus upstream not configured in cert_manager\n"
{% endif %}

backend nexus_docker_group_tcp
  mode http
{% if haproxy_nexus_upstream_configured | default(false) | bool %}
  balance source
  option httplog
  server nexus_docker_group_1 {{ haproxy_nexus_upstream_host }}:{{ haproxy_nexus_docker_group_upstream_port }} check
{% else %}
  http-request return status 503 content-type text/plain string "Nexus upstream not configured in cert_manager\n"
{% endif %}

# L7 → Traefik: клиентские заголовки (Authorization, Idempotency-Key, CORS preflight и т.д.)
# пробрасываются по умолчанию; tune.bufsize/maxrewrite в global — под длинные блоки заголовков.
backend traefik_web_upstream
  mode http
  balance roundrobin
{% for h in _traefik_nodes %}
  server traefik_web_{{ loop.index }} {{ hostvars[h].ansible_host | default(h) }}:{{ haproxy_traefik_web_port | default(8080) }} check
{% endfor %}

backend traefik_websecure_upstream
  mode tcp
  balance roundrobin
  option tcp-check
{% for h in _traefik_nodes %}
  server traefik_websecure_{{ loop.index }} {{ hostvars[h].ansible_host | default(h) }}:{{ haproxy_traefik_websecure_port | default(8443) }} check
{% endfor %}

{# Direct app backends from cert_manager slots (HAProxy -> swarm managers, bypass Traefik). #}
{% if _route_apps_direct %}
{% for site in _app_sites %}
{% set _site_idx = loop.index %}
{% set _site_domains = site.domains | default([]) %}
{% set _site_backend_name = (
  'app_'
  ~ (
    site.cert_name
    | default(site.service_name | default(site.router_name | default('site')))
    | lower
    | regex_replace('[^a-z0-9]+', '_')
    | regex_replace('^_+', '')
    | regex_replace('_+$', '')
  )
  ~ '_' ~ (_site_idx | string) ~ '_upstream'
) %}
{% if _site_domains is string %}
{% set _site_domains = [_site_domains] %}
{% endif %}
{% if (_site_domains | length) == 0 and (site.cert_name is defined) %}
{% set _site_domains = [site.cert_name] %}
{% endif %}
{% if (_site_domains | length) > 0 %}
backend {{ _site_backend_name }}
  mode http
  balance roundrobin
{% set _site_middlewares = site.middlewares | default([]) %}
{% if _site_middlewares is string %}
{% set _site_middlewares = [_site_middlewares] %}
{% endif %}
{% set _site_middlewares_lc = (_site_middlewares | map('string') | map('lower') | list) %}
{% if 'retry' in _site_middlewares_lc %}
  retries 3
  option redispatch
{% endif %}
{% if 'compress' in _site_middlewares_lc %}
  compression algo gzip
  compression type text/plain text/css text/javascript application/javascript application/json application/xml text/xml text/html
{% endif %}
{% if 'hsts' in _site_middlewares_lc %}
  http-response set-header Strict-Transport-Security "max-age=31536000; includeSubDomains"
{% endif %}
{% if 'cors' in _site_middlewares_lc %}
  http-request return status 204 hdr Access-Control-Allow-Origin "*" hdr Access-Control-Allow-Credentials "true" hdr Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS" hdr Access-Control-Allow-Headers "*" if METH_OPTIONS
  http-response set-header Access-Control-Allow-Origin "*"
  http-response set-header Access-Control-Allow-Credentials "true"
  http-response set-header Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS"
  http-response set-header Access-Control-Allow-Headers "*"
{% endif %}
{% if _app_use_slot_upstream_host and ((site.upstream_host | default('') | trim | length) > 0) %}
  server app_upstream_{{ _site_idx }} {{ site.upstream_host | trim }}:{{ site.upstream_port | int }} check
{% else %}
{% for h in _app_upstream_nodes %}
  server app_upstream_{{ _site_idx }}_{{ loop.index }} {{ hostvars[h].ansible_host | default(h) }}:{{ site.upstream_port | int }} check
{% endfor %}
{% endif %}

{% endif %}
{% endfor %}
{% endif %}

{# --- Docker registry TCP (HAProxy -> Nexus) --- #}
{# 9080 = docker-hosted, 9081 = docker-proxy, 9082 = docker-group #}
frontend docker_hosted_in
{% if haproxy_docker_tls_termination | default(false) | bool %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_docker_hosted_port | default(9080) }} ssl crt {{ haproxy_ssl_fullchain_path }}
{% else %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_docker_hosted_port | default(9080) }}
{% endif %}
  mode http
{% if haproxy_docker_tls_termination | default(false) | bool %}
  http-request set-header X-Forwarded-Proto https
{% endif %}
  default_backend nexus_docker_hosted_tcp

frontend docker_proxy_in
{% if haproxy_docker_tls_termination | default(false) | bool %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_docker_proxy_port | default(9081) }} ssl crt {{ haproxy_ssl_fullchain_path }}
{% else %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_docker_proxy_port | default(9081) }}
{% endif %}
  mode http
{% if haproxy_docker_tls_termination | default(false) | bool %}
  http-request set-header X-Forwarded-Proto https
{% endif %}
  default_backend nexus_docker_proxy_tcp

frontend docker_group_in
{% if haproxy_docker_tls_termination | default(false) | bool %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_docker_group_port | default(9082) }} ssl crt {{ haproxy_ssl_fullchain_path }}
{% else %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_docker_group_port | default(9082) }}
{% endif %}
  mode http
{% if haproxy_docker_tls_termination | default(false) | bool %}
  http-request set-header X-Forwarded-Proto https
{% endif %}
  default_backend nexus_docker_group_tcp

{% if (haproxy_gitlab_ssh_proxy_enabled | default(false) | bool) and (haproxy_gitlab_upstream_configured | default(false) | bool) %}
frontend gitlab_ssh_in
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_gitlab_ssh_listen_port | default(2222) }}
  mode tcp
  default_backend gitlab_ssh_tcp
{% endif %}

{# Safe fallback backend for include-mode / non-swarm mode. #}
backend direct_layer7
  mode http
  http-request return status 503 content-type text/plain string "No upstream configured\n"

backend direct_layer7_tcp
  mode tcp
  tcp-request content reject

{# ACME HTTP-01 challenge backend (cert-manager) #}
backend certmanager_acme_http01
  mode http
  balance roundrobin
  option httpchk GET /.well-known/acme-challenge/healthz
{% if (cert_manager_deploy_method | default('compose')) == 'compose' %}
  # docker compose on this host → publish certbot-web on loopback and proxy locally
  server certmgr_local 127.0.0.1:{{ cert_manager_publish_http_port | default(8088) }} check
{% else %}
{% set _cm_up = (groups['cert_manager'] | default([])) %}
{% for h in _cm_up %}
  server certmgr_{{ loop.index }} {{ hostvars[h].ansible_host | default(h) }}:{{ cert_manager_publish_http_port | default(8088) }} check
{% endfor %}
{% endif %}

{% if haproxy_acl_enabled | default(false) %}
{% if haproxy_allow_host_regex | default([]) | length > 0 %}
{% set _host_patterns = haproxy_allow_host_regex %}
{% else %}
{% set _host_patterns = [
  '^([a-zA-Z0-9-]+\\.)*' ~ (app_domain_name | regex_escape) ~ '$',
  '^' ~ (app_domain_name | regex_escape) ~ '$'
] %}
{% endif %}
{% endif %}

{# /stats по IP: только при firewall_lockdown=true и списке из inventory; иначе ограничение по src не применяется #}
{% if firewall_lockdown | default(false) | bool %}
{% set _stats_cidrs = (firewall_trusted_admin_cidrs | default([])) | map('trim') | reject('equalto', '') | list | unique %}
{% else %}
{% set _stats_cidrs = [] %}
{% endif %}

frontend http-in
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_http_port | default(80) }}
  mode http
  http-request add-header X-Forwarded-Proto http
{% if firewall_lockdown | default(false) | bool %}
{% if _stats_cidrs | length > 0 %}
  acl stats_from_trusted src -f /etc/haproxy/stats-trusted.cidr
  http-request deny deny_status 403 if { path_beg /stats } !stats_from_trusted
{% else %}
  http-request deny deny_status 403 if { path_beg /stats }
{% endif %}
{% endif %}
  acl acme_challenge path_beg /.well-known/acme-challenge/
  use_backend certmanager_acme_http01 if acme_challenge
  acl host_nexus_http hdr(host),field(1,:),lower -i nexus.{{ app_domain_name | lower }}
  acl is_nexus_v2_http path_beg /v2/
{% if haproxy_nexus_route_v2_to_docker_hosted | default(true) | bool %}
  use_backend nexus_docker_hosted_tcp if host_nexus_http is_nexus_v2_http
{% endif %}
  use_backend nexus_websecure_tcp if host_nexus_http
{% if _route_apps_direct %}
{% for site in _app_sites %}
{% set _site_domains = site.domains | default([]) %}
{% set _site_acl_name = (
  'host_app_'
  ~ (
    site.cert_name
    | default(site.service_name | default(site.router_name | default('site')))
    | lower
    | regex_replace('[^a-z0-9]+', '_')
    | regex_replace('^_+', '')
    | regex_replace('_+$', '')
  )
  ~ '_' ~ (loop.index | string)
) %}
{% set _site_backend_name = (
  'app_'
  ~ (
    site.cert_name
    | default(site.service_name | default(site.router_name | default('site')))
    | lower
    | regex_replace('[^a-z0-9]+', '_')
    | regex_replace('^_+', '')
    | regex_replace('_+$', '')
  )
  ~ '_' ~ (loop.index | string) ~ '_upstream'
) %}
{% if _site_domains is string %}
{% set _site_domains = [_site_domains] %}
{% endif %}
{% if (_site_domains | length) == 0 and (site.cert_name is defined) %}
{% set _site_domains = [site.cert_name] %}
{% endif %}
{% if (_site_domains | length) > 0 %}
  acl {{ _site_acl_name }} hdr(host),field(1,:),lower -i{% for d in _site_domains %} {{ d | lower }}{% endfor %}
  use_backend {{ _site_backend_name }} if {{ _site_acl_name }}

{% endif %}
{% endfor %}
{% endif %}
{# В текущей архитектуре HAProxy делает апстрим до Traefik "по умолчанию".
   Маршрутизацию по доменам/приложениям делает Traefik (dynamic config), а не HAProxy. #}
{% if haproxy_acl_enabled | default(false) %}
  acl good_host hdr_reg(host) -i{% for r in _host_patterns %} {{ r }}{% endfor %}
{% if haproxy_allow_uri_regex | default([]) | length > 0 %}
  acl good_path path_reg -i{% for r in haproxy_allow_uri_regex %} {{ r }}{% endfor %}
  http-request deny deny_status 403 if !good_host || !good_path
{% else %}
  http-request deny deny_status 403 if !good_host
{% endif %}
{% endif %}

{% if _route_to_traefik %}
  default_backend traefik_web_upstream
{% else %}
  # Базовый HTTP upstream можно настроить отдельно при необходимости.
  default_backend direct_layer7
{% endif %}

{% if haproxy_https_enabled | default(true) | bool %}
frontend https_in
{% if (haproxy_https_mode | default('http_terminate')) == 'tcp_passthrough' %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_https_port | default(443) }}
  mode tcp
{% if _route_to_traefik %}
  default_backend traefik_websecure_upstream
{% else %}
  default_backend direct_layer7_tcp
{% endif %}
{% else %}
  bind {{ haproxy_bind_ip | default(ansible_default_ipv4.address) }}:{{ haproxy_https_port | default(443) }} ssl crt {{ haproxy_ssl_fullchain_path }}
  mode http
  http-request set-header X-Forwarded-Proto https
  acl host_gitlab hdr(host),field(1,:),lower -i gitlab.{{ app_domain_name | lower }}
  acl host_nexus hdr(host),field(1,:),lower -i nexus.{{ app_domain_name | lower }}
  acl is_nexus_v2 path_beg /v2/
{% if firewall_lockdown | default(false) | bool %}
{% if _stats_cidrs | length > 0 %}
  acl stats_from_trusted_ssl src -f /etc/haproxy/stats-trusted.cidr
  http-request deny deny_status 403 if !stats_from_trusted_ssl
{% else %}
  http-request deny deny_status 403
{% endif %}
{% endif %}
{% if haproxy_nexus_route_v2_to_docker_hosted | default(true) | bool %}
  use_backend nexus_docker_hosted_tcp if host_nexus is_nexus_v2
{% endif %}
  use_backend nexus_websecure_tcp if host_nexus
  use_backend gitlab_https_tcp if host_gitlab
{% if _route_apps_direct %}
{% for site in _app_sites %}
{% set _site_domains = site.domains | default([]) %}
{% set _site_acl_name = (
  'host_app_tls_'
  ~ (
    site.cert_name
    | default(site.service_name | default(site.router_name | default('site')))
    | lower
    | regex_replace('[^a-z0-9]+', '_')
    | regex_replace('^_+', '')
    | regex_replace('_+$', '')
  )
  ~ '_' ~ (loop.index | string)
) %}
{% set _site_backend_name = (
  'app_'
  ~ (
    site.cert_name
    | default(site.service_name | default(site.router_name | default('site')))
    | lower
    | regex_replace('[^a-z0-9]+', '_')
    | regex_replace('^_+', '')
    | regex_replace('_+$', '')
  )
  ~ '_' ~ (loop.index | string) ~ '_upstream'
) %}
{% if _site_domains is string %}
{% set _site_domains = [_site_domains] %}
{% endif %}
{% if (_site_domains | length) == 0 and (site.cert_name is defined) %}
{% set _site_domains = [site.cert_name] %}
{% endif %}
{% if (_site_domains | length) > 0 %}
  acl {{ _site_acl_name }} hdr(host),field(1,:),lower -i{% for d in _site_domains %} {{ d | lower }}{% endfor %}
  use_backend {{ _site_backend_name }} if {{ _site_acl_name }}

{% endif %}
{% endfor %}
{% endif %}
{# Без записей gitlab.*/nexus.* в cert_manager — весь остальной HTTPS на Traefik (как HTTP-фронт). #}
{% if _route_to_traefik %}
  default_backend traefik_web_upstream
{% else %}
  default_backend direct_layer7
{% endif %}
{% endif %}
{% endif %}

