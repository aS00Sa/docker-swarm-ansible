version: '3.8'

services:
  {{ portainer_edge_service_name }}:
    image: {{ portainer_agent_image }}
    environment:
      TZ: Europe/Moscow
      EDGE: "1"
      EDGE_ID: "{{ portainer_edge_id }}"
      EDGE_KEY: "{{ portainer_edge_key }}"
      EDGE_INSECURE_POLL: "{{ (portainer_edge_insecure_poll | bool) | ternary('1', '0') }}"
      AGENT_SECRET: "{{ portainer_agent_secret }}"
      AGENT_CLUSTER_ADDR: "tasks.{{ portainer_edge_service_name }}"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /var/lib/docker/volumes:/var/lib/docker/volumes
      - /:/host
      - {{ portainer_edge_agent_data_volume }}:/data
    networks:
      - {{ portainer_edge_network_name }}
    deploy:
      mode: global
      placement:
        constraints: [node.platform.os == linux]

networks:
  {{ portainer_edge_network_name }}:
    driver: overlay
    attachable: true
    name: {{ portainer_edge_network_name }}

volumes:
  {{ portainer_edge_agent_data_volume }}:
    driver: local
