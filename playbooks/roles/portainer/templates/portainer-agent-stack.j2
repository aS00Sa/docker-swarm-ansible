version: '3.5'

services:
  agent:
    image: {{ portainer_agent_image }}
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - /var/lib/docker/volumes:/var/lib/docker/volumes
    networks:
      - {{portainer_network_name}}
    environment:
      TZ: Europe/Moscow
      AGENT_SECRET: {{portainer_agent_secret}}
      AGENT_PORT: {{portainer_agent_port}}
    deploy:
      mode: global
      placement:
        constraints: [node.platform.os == linux]

  portainer:
    image: {{ portainer_image }}
    command: "-H tcp://tasks.agent:{{portainer_agent_port}} --tlsskipverify --bind :{{portainer_admin_port}} --tunnel-port {{portainer_tunnel_port}} --admin-password {{portainerpassword.stdout}}"
    ports:
      - "{{portainer_admin_port}}:{{portainer_admin_port}}"
      - "{{portainer_tunnel_port}}:{{portainer_tunnel_port}}"
    volumes:
      - {{portainer_volume_name}}:/data
    networks:
      - {{portainer_network_name}}
    environment:
      TZ: Europe/Moscow
      AGENT_SECRET: {{portainer_agent_secret}}
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints: [node.role == manager]

networks:
  {{portainer_network_name}}:
    driver: overlay
    attachable: true
    name: {{portainer_network_name}}

volumes:
  {{portainer_volume_name}}:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ gluster_mount_path }}/{{ portainer_gfs_subdir }}
