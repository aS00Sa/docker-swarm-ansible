api:
  dashboard: true

entryPoints:
  web:
    address: ":{{ traefik_http_port }}"
    transport:
      forwardingTimeouts:
        # Долгие аплоады (GitLab runner -> GitLab) не должны обрываться прокси из-за таймаутов.
        dialTimeout: 600s
        responseHeaderTimeout: 0s
        idleTimeout: 0s
        responseForwardingTimeout: 0s
      respondingTimeouts:
        readTimeout: 0s
        writeTimeout: 0s
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https  
  websecure:
    address: ":{{ traefik_https_port }}"
    transport:
      forwardingTimeouts:
        dialTimeout: 600s
        responseHeaderTimeout: 0s
        idleTimeout: 0s
        responseForwardingTimeout: 0s
      respondingTimeouts:
        readTimeout: 0s
        writeTimeout: 0s
  traefik:
    address: ":{{ traefik_internal_api_port }}"

providers:
  swarm:
    endpoint: "unix:///var/run/docker.sock"
    watch: true
    exposedByDefault: false
    network: "{{ traefik_network_name }}"
  file:
    directory: /etc/traefik/dynamic
    watch: true

certificatesResolvers:
  letsencrypt:
    acme:
      email: "admin@sprtbt.com"
      storage: "/etc/traefik/acme.json"
      httpChallenge:
        entryPoint: web

log:
  level: INFO

accessLog: {}
