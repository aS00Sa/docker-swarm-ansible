api:
  dashboard: true

entryPoints:
  web:
    address: ":{{ haproxy_traefik_web_port | default(8080) }}"
    transport:
      # Долгие аплоады не должны обрываться прокси из-за таймаутов.
      respondingTimeouts:
        readTimeout: 0s
        writeTimeout: 0s
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https  
  websecure:
    address: ":{{ haproxy_traefik_websecure_port | default(8443) }}"
    proxyProtocol:
      insecure: true
    transport:
      respondingTimeouts:
        readTimeout: 0s
        writeTimeout: 0s

  traefik:
    address: ":{{ traefik_internal_api_port }}"

providers:
{% set _eff_method = traefik_effective_deploy_method | default(traefik_deploy_method | default('auto')) %}
{% if _eff_method == 'compose' %}
  docker:
    endpoint: "unix:///var/run/docker.sock"
    watch: true
    exposedByDefault: false
{% else %}
  swarm:
    endpoint: "unix:///var/run/docker.sock"
    watch: true
    exposedByDefault: false
    network: "{{ traefik_network_name }}"
{% endif %}
  file:
    directory: /etc/traefik/dynamic
    watch: true

serversTransport:
  forwardingTimeouts:
    # Таймауты upstream-соединений (Traefik -> backend, напр. GitLab/Nexus)
    dialTimeout: 600s
    responseHeaderTimeout: 0s
    idleConnTimeout: 0s

{% if traefik_acme_enabled | default(false) | bool %}
certificatesResolvers:
  {{ traefik_acme_resolver_name | default('letsencrypt') }}:
    acme:
      email: "{{ traefik_acme_email | default('admin@' ~ app_domain_name) }}"
      storage: "{{ traefik_acme_storage_path | default('/etc/traefik/acme.json') }}"
      httpChallenge:
        entryPoint: web
{% endif %}

log:
  level: INFO

accessLog: {}
