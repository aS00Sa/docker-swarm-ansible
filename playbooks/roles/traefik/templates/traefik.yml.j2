api:
  dashboard: true

entryPoints:
  web:
    address: ":{{ traefik_http_port }}"
    transport:
      forwardingTimeouts:
        # Долгие аплоады (GitLab runner -> GitLab) не должны обрываться прокси из-за таймаутов.
        dialTimeout: 600s
        responseHeaderTimeout: 0s
        idleTimeout: 0s
        responseForwardingTimeout: 0s
      respondingTimeouts:
        readTimeout: 0s
        writeTimeout: 0s
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https  
  websecure:
    address: ":{{ traefik_https_port }}"
    transport:
      forwardingTimeouts:
        dialTimeout: 600s
        responseHeaderTimeout: 0s
        idleTimeout: 0s
        responseForwardingTimeout: 0s
      respondingTimeouts:
        readTimeout: 0s
        writeTimeout: 0s
  traefik:
    address: ":{{ traefik_internal_api_port }}"

providers:
  swarm:
    endpoint: "unix:///var/run/docker.sock"
    watch: true
    exposedByDefault: false
    network: "{{ traefik_network_name }}"
  file:
    directory: /etc/traefik/dynamic
    watch: true

{% if traefik_acme_enabled | default(false) | bool %}
certificatesResolvers:
  {{ traefik_acme_resolver_name | default('letsencrypt') }}:
    acme:
      email: "{{ traefik_acme_email | default('admin@' ~ app_domain_name) }}"
      storage: "{{ traefik_acme_storage_path | default('/etc/traefik/acme.json') }}"
      httpChallenge:
        entryPoint: web
{% endif %}

log:
  level: INFO

accessLog: {}
