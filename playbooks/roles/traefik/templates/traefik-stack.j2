# traefik_version: {{ traefik_version }}
version: '3.5'

# Вход HTTP(S) для приложений — не порты haproxy_http_port / haproxy_https_port на хосте (их занимает HAProxy).
# Публикация на всех интерфейсах: доступ с нод кластера для балансировки HAProxy по upstream.
# Внутри контейнера: web → traefik_http_port, websecure → traefik_https_port, traefik (API) → traefik_internal_api_port.
services:
  traefik:
    image: traefik:{{ traefik_version }}
    command:
      - "--configFile=/etc/traefik/traefik.yml"
    environment:
      TZ: Europe/Moscow
    ports:
      - target: {{ haproxy_traefik_web_port | default(8080) }}
        published: {{ haproxy_traefik_web_port | default(8080) }}
        protocol: tcp
        mode: host
      - target: {{ haproxy_traefik_websecure_port | default(8443) }}
        published: {{ haproxy_traefik_websecure_port | default(8443) }}
        protocol: tcp
        mode: host
      - target: {{ traefik_internal_api_port }}
        published: {{ traefik_internal_api_port }}
        protocol: tcp
        mode: host
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
      - traefik-acme:/etc/traefik
      - {{ gluster_mount_path }}/{{ traefik_gfs_subdir }}/traefik.yml:/etc/traefik/traefik.yml:ro
      - {{ gluster_mount_path }}/{{ traefik_gfs_subdir }}/{{ traefik_dynamic_subdir }}:/etc/traefik/dynamic:ro
      - {{ gluster_mount_path }}/{{ cert_manager_gfs_subdir | default('cert_manager_gfs') }}/{{ cert_manager_letsencrypt_subdir | default('letsencrypt') }}:/etc/traefik/letsencrypt:ro
      - traefik_data:/data
    networks:
      - {{ traefik_network_name }}
    deploy:
      labels:
      - "traefik.enable=true"
      - "traefik.http.routers.api.rule=Host(`{{traefik_app_name}}.{{app_domain_name}}`)"
      - "traefik.http.routers.api.service=api@internal"
      - "traefik.http.routers.api.middlewares=auth"
      - "traefik.http.routers.api.entrypoints=traefik"
      - "traefik.http.middlewares.auth.basicauth.users={{traefikpassword.stdout}}"
      - "traefik.http.services.dummy-svc.loadbalancer.server.port=9999"
      mode: {{ traefik_deploy_mode | default('global') }}
{% if (traefik_deploy_mode | default('global')) == 'replicated' %}
      replicas: {{ traefik_replicas | default(1) | int }}
{% endif %}
      placement:
{% if (traefik_deploy_mode | default('global')) == 'replicated' and (traefik_replicas | default(1) | int) == 1 and (traefik_pin_to_leader | default(true)) %}
        constraints:
          - "node.labels.traefik == true"
          - "node.hostname == {{ traefik_deploy_constraint_hostname }}"
{% else %}
        constraints:
          - "node.labels.traefik == true"
{% endif %}

networks:
  {{ traefik_network_name }}:
    driver: overlay
    attachable: true
    name: {{ traefik_network_name }}

volumes:
  traefik_data:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ gluster_mount_path }}/{{ traefik_gfs_subdir }}

  traefik-acme:
    driver: local
    driver_opts:
      type: none
      o: bind
      device: {{ gluster_mount_path }}/{{ traefik_gfs_subdir }}
