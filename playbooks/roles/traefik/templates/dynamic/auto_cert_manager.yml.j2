{% set _c = cert_item %}
{% set _cn = (_c.cert_name | default(_c.domains | first)) %}
{% set _name = (_cn | regex_replace('[^a-zA-Z0-9_-]', '-') | lower) %}
{% set _servers_transport = 'upstream-long-timeouts-' ~ _name %}
{% set _c_servers = _c.upstream_servers | default([]) %}
{% set _c_host = _c.upstream_host | default('') | trim %}
{% set _c_scheme = _c.upstream_scheme | default('http') %}
{% set _c_port = _c.upstream_port | default(80) %}
{% set _default_h = traefik_default_upstream_host | default('') | trim %}
{% set _cors_allow_headers = _c.cors_allow_headers | default(traefik_cors_allow_headers | default([])) %}
{% set _router_name = _c.router_name | default('site-' ~ _name) %}
{% set _service_name = _c.service_name | default('svc-' ~ _name) %}
{% set _middlewares = _c.middlewares | default([]) %}
{% set _entrypoints = _c.entrypoints | default([]) %}
{% if _entrypoints | length == 0 %}
{% if _c.entrypoint is defined %}
{% set _entrypoints = [_c.entrypoint] %}
{% else %}
{% set _entrypoints = ['websecure'] %}
{% endif %}
{% endif %}
{% set _ports_by_entrypoint = _c.upstream_ports_by_entrypoint | default(_c.upstream_ports_by_entrypoints | default({})) %}
{% set _has_ports_map = (_ports_by_entrypoint | default({}) | length) > 0 %}
{% set _mw_compress_name = _name ~ '-compress' %}
{% set _mw_hsts_name = _name ~ '-hsts' %}
{% set _mw_retry_name = _name ~ '-retry' %}
{% set _mw_cors_name = _name ~ '-cors' %}
{% set _mw_ipallow_name = _name ~ '-ipallow' %}
{# ipAllowList: ключ ip_allowlist в слоте cert_manager, либо middleware "ipallowlist" → fallback firewall_trusted_admin_cidrs из inventory. #}
{% set _explicit_ip_allow = _c.ip_allowlist | default([]) %}
{% set _ipallow_mw_requested = ('ipallowlist' in _middlewares) %}
{% if _ipallow_mw_requested %}
{% set _ip_ranges_eff = _explicit_ip_allow if (_explicit_ip_allow | length > 0) else (firewall_trusted_admin_cidrs | default([])) %}
{% else %}
{% set _ip_ranges_eff = _explicit_ip_allow %}
{% endif %}
{% set _ipallow_on = (_ip_ranges_eff | length > 0) and (_ipallow_mw_requested or (_explicit_ip_allow | length > 0)) %}
{# Пул upstream без upstream_host/upstream_servers: приоритет traefik_default_upstream_host (ниже, _default_h).
   Иначе непустой [test_backend] → только он; иначе [swarm_managers] (не workers). #}
{% set _tb = groups.get('test_backend', []) | list %}
{% set _mgr = groups.get('swarm_managers', []) | list %}
{% if (_tb | length) > 0 %}
{% set _backend_hosts = _tb %}
{% else %}
{% set _backend_hosts = _mgr %}
{% endif %}
{% set _pass_host = _c.pass_host_header | default(_c.traefik_pass_host_header | default(traefik_auto_site_pass_host_header | default(true))) | bool %}
{% set _hc_enabled = _c.health_check_enabled | default(_c.traefik_health_check_enabled | default(traefik_auto_site_health_check_enabled | default(true))) | bool %}
{% set _hc_path = _c.health_check_path | default(_c.traefik_health_check_path | default(traefik_auto_site_health_check_path | default('/ping'))) %}
{% set _hc_interval = _c.health_check_interval | default(_c.traefik_health_check_interval | default(traefik_auto_site_health_check_interval | default('10s'))) %}
{% set _hc_timeout = _c.health_check_timeout | default(_c.traefik_health_check_timeout | default(traefik_auto_site_health_check_timeout | default('5s'))) %}
tls:
  certificates:
    - certFile: "/etc/traefik/letsencrypt/live/{{ _cn }}/fullchain.pem"
      keyFile: "/etc/traefik/letsencrypt/live/{{ _cn }}/privkey.pem"

http:
{% if (_middlewares | length > 0) or _ipallow_on %}
  middlewares:
{% if _ipallow_on %}
    {{ _mw_ipallow_name }}:
      ipAllowList:
        sourceRange:
{% for cidr in _ip_ranges_eff %}
          - "{{ cidr }}"
{% endfor %}
{% endif %}
{% if 'compress' in _middlewares %}
    {{ _mw_compress_name }}:
      compress: {}
{% endif %}
{% if 'hsts' in _middlewares %}
    {{ _mw_hsts_name }}:
      headers:
        stsSeconds: 31536000
        stsIncludeSubdomains: true
        stsPreload: true
{% endif %}
{% if 'retry' in _middlewares %}
    {{ _mw_retry_name }}:
      retry:
        attempts: 3
        initialInterval: "100ms"
{% endif %}
{% if 'cors' in _middlewares %}
    {{ _mw_cors_name }}:
      headers:
{% set _cors_origins = _c.cors_allow_origin_list | default(traefik_cors_allow_origin_list | default([])) %}
{% if _cors_origins | length > 0 %}
        accessControlAllowOriginList:
{% for o in _cors_origins %}
          - {{ o | to_json }}
{% endfor %}
{% else %}
        accessControlAllowOriginListRegex:
{% for r in (traefik_cors_allow_origin_list_regex | default(['.*'])) %}
          - "{{ r }}"
{% endfor %}
{% endif %}
        accessControlAllowMethods:
          - GET
          - POST
          - PUT
          - DELETE
          - OPTIONS
          - PATCH
        accessControlAllowHeaders:
{% for h in _cors_allow_headers %}
          - {{ h | to_json }}
{% endfor %}
        accessControlAllowCredentials: true
        addVaryHeader: true
        accessControlMaxAge: 3600
{% endif %}
{% endif %}

  serversTransports:
    {{ _servers_transport }}:
      forwardingTimeouts:
        dialTimeout: 600s
        responseHeaderTimeout: 0s
        idleConnTimeout: 0s

{% set mw_chain = namespace(items=[]) %}
{% if _ipallow_on %}
{% set _ = mw_chain.items.append(_mw_ipallow_name) %}
{% endif %}
{% if 'cors' in _middlewares %}
{% set _ = mw_chain.items.append(_mw_cors_name) %}
{% endif %}
{% if 'compress' in _middlewares %}
{% set _ = mw_chain.items.append(_mw_compress_name) %}
{% endif %}
{% if 'hsts' in _middlewares %}
{% set _ = mw_chain.items.append(_mw_hsts_name) %}
{% endif %}
{% if 'retry' in _middlewares %}
{% set _ = mw_chain.items.append(_mw_retry_name) %}
{% endif %}
  routers:
{% if _has_ports_map %}
{% for ep in _entrypoints %}
{% set _ep_safe = (ep | regex_replace('[^a-zA-Z0-9_-]', '-') ) %}
    {{ _router_name }}-{{ _ep_safe }}:
      rule: "{% for d in (_c.domains | default([])) %}Host(`{{ d }}`){% if not loop.last %} || {% endif %}{% endfor %}"
      service: {{ _service_name }}-{{ _ep_safe }}
      entryPoints: [{{ ep }}]
      tls: {}
{% if (mw_chain.items | length) > 0 %}
      middlewares: [{{ mw_chain.items | join(', ') }}]
{% endif %}
{% endfor %}
{% else %}
    {{ _router_name }}:
      rule: "{% for d in (_c.domains | default([])) %}Host(`{{ d }}`){% if not loop.last %} || {% endif %}{% endfor %}"
      service: {{ _service_name }}
      entryPoints: [{% for ep in _entrypoints %}{{ ep }}{% if not loop.last %}, {% endif %}{% endfor %}]
      tls: {}
{% if (mw_chain.items | length) > 0 %}
      middlewares: [{{ mw_chain.items | join(', ') }}]
{% endif %}
{% endif %}

  services:
{% if _has_ports_map %}
{% for ep in _entrypoints %}
{% set _ep_safe = (ep | regex_replace('[^a-zA-Z0-9_-]', '-') ) %}
{% set _port_for_ep = _ports_by_entrypoint.get(ep, _c_port) %}
    {{ _service_name }}-{{ _ep_safe }}:
      loadBalancer:
        serversTransport: {{ _servers_transport }}
        servers:
{% if _c_servers | length > 0 %}
{% for u in _c_servers %}
          - { url: "{{ u }}" }
{% endfor %}
{% elif _c_host | length > 0 %}
          - { url: "{{ _c_scheme }}://{{ _c_host }}:{{ _port_for_ep }}" }
{% elif _default_h | length > 0 %}
          - { url: "{{ _c_scheme }}://{{ _default_h }}:{{ _port_for_ep }}" }
{% else %}
{% for h in _backend_hosts %}
          - { url: "{{ _c_scheme }}://{{ hostvars[h].ansible_host | default(h) }}:{{ _port_for_ep }}" }
{% endfor %}
{% endif %}
        passHostHeader: {{ _pass_host | bool | to_json }}
{% if _hc_enabled | bool %}
        healthCheck:
          path: {{ _hc_path | to_json }}
          interval: {{ _hc_interval | to_json }}
          timeout: {{ _hc_timeout | to_json }}
{% endif %}
{% endfor %}
{% else %}
    {{ _service_name }}:
      loadBalancer:
        serversTransport: {{ _servers_transport }}
        servers:
{% if _c_servers | length > 0 %}
{% for u in _c_servers %}
          - { url: "{{ u }}" }
{% endfor %}
{% elif _c_host | length > 0 %}
          - { url: "{{ _c_scheme }}://{{ _c_host }}:{{ _c_port }}" }
{% elif _default_h | length > 0 %}
          - { url: "{{ _c_scheme }}://{{ _default_h }}:{{ _c_port }}" }
{% else %}
{% for h in _backend_hosts %}
          - { url: "{{ _c_scheme }}://{{ hostvars[h].ansible_host | default(h) }}:{{ _c_port }}" }
{% endfor %}
{% endif %}
        passHostHeader: {{ _pass_host | bool | to_json }}
{% if _hc_enabled | bool %}
        healthCheck:
          path: {{ _hc_path | to_json }}
          interval: {{ _hc_interval | to_json }}
          timeout: {{ _hc_timeout | to_json }}
{% endif %}
{% endif %}
