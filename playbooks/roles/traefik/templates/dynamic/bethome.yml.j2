{# Не деплоится ролью: маршруты bthm.* задаются через cert_manager + auto_cert_manager.yml.j2 → sites/bthm_*_….yml #}
{% set _tb = groups.get('test_backend', []) | list %}
{% set _mgr = groups.get('swarm_managers', []) | list %}
{% if (_tb | length) > 0 %}
{% set traefik_backend_hosts = _tb %}
{% else %}
{% set traefik_backend_hosts = _mgr %}
{% endif %}
{% set _cors_allow_headers = cors_allow_headers | default([]) %}
http:
  middlewares:
    allow-cors:
      headers:
{% set _cors_origins = cors_allow_origin_list | default([]) %}
{% if _cors_origins | length > 0 %}
        accessControlAllowOriginList:
{% for o in _cors_origins %}
          - {{ o | to_json }}
{% endfor %}
{% else %}
        accessControlAllowOriginListRegex:
{% for r in (cors_allow_origin_list_regex | default(['.*'])) %}
          - "{{ r }}"
{% endfor %}
{% endif %}
        accessControlAllowMethods:
            - GET
            - POST
            - PUT
            - DELETE
            - OPTIONS
            - PATCH 
        accessControlAllowHeaders:
{% for h in _cors_allow_headers %}
            - {{ h | to_json }}
{% endfor %}
        accessControlAllowCredentials: true
        addVaryHeader: true
        accessControlMaxAge: 3600
  routers:
    bethome-server:
      rule: "Host(`bthm.server.{{ app_domain_name }}`)"
      service: bethome-server
      entryPoints: [websecure]
      tls: {}
      middlewares: [allow-cors]
    bethome-cdn:
      rule: "Host(`bthm.cdn.{{ app_domain_name }}`)"
      service: bethome-cdn
      entryPoints: [websecure]
      tls: {}
      middlewares: [allow-cors]
    bethome-stream:
      rule: "Host(`bthm.stream.{{ app_domain_name }}`)"
      service: bethome-stream
      entryPoints: [websecure]
      tls: {}
      middlewares: [allow-cors]
    bethome-admin:
      rule: "Host(`bthm.admin.{{ app_domain_name }}`)"
      service: bethome-admin
      entryPoints: [websecure]
      tls: {}
      middlewares: [allow-cors]

  services:
    bethome-server:
      loadBalancer:
        servers:
{% for backend_host in traefik_backend_hosts %}
          - { url: "http://{{ hostvars[backend_host].ansible_host | default(backend_host) }}:5000" }
{% endfor %}
        passHostHeader: true
        healthCheck:
          path: "/ping"
          interval: "10s"
          timeout: "5s"
    bethome-cdn:
      loadBalancer:
        servers:
{% for backend_host in traefik_backend_hosts %}
          - { url: "http://{{ hostvars[backend_host].ansible_host | default(backend_host) }}:5010" }
{% endfor %}
        passHostHeader: true
        healthCheck:
          path: "/ping"
          interval: "10s"
          timeout: "5s"
    bethome-stream:
      loadBalancer:
        servers:
{% for backend_host in traefik_backend_hosts %}
          - { url: "http://{{ hostvars[backend_host].ansible_host | default(backend_host) }}:5020" }
{% endfor %}
        passHostHeader: true
        healthCheck:
          path: "/ping"
          interval: "10s"
          timeout: "5s"
    bethome-admin:
      loadBalancer:
        servers:
{% for backend_host in traefik_backend_hosts %}
          - { url: "http://{{ hostvars[backend_host].ansible_host | default(backend_host) }}:5030" }
{% endfor %}
        passHostHeader: true
        healthCheck:
          path: "/ping"
          interval: "10s"
          timeout: "5s"
    
