{% set _sites = traefik_upstream_sites | default([]) %}
{% set _certs = cert_manager_certs | default([]) %}
{% set _backend_hosts = groups.get('swarm_workers', []) %}
{% if _backend_hosts | length == 0 %}
{% set _backend_hosts = groups.get('test_backend', []) %}
{% endif %}
{% if (_sites | length == 0) and (_certs | length == 0) %}
# No generated Traefik upstream sites (traefik_upstream_sites and cert_manager_certs are empty).
{% else %}
http:
  routers:
{% if _sites | length > 0 %}
{% for s in _sites %}
    site-{{ (s.name | default('site-' ~ loop.index)) | regex_replace('[^a-zA-Z0-9_-]', '-') | lower }}:
      rule: "{% for d in (s.domains | default([])) %}Host(`{{ d }}`){% if not loop.last %} || {% endif %}{% endfor %}"
      service: svc-{{ (s.name | default('site-' ~ loop.index)) | regex_replace('[^a-zA-Z0-9_-]', '-') | lower }}
      entryPoints: [{% for ep in (s.entrypoints | default(['websecure'])) %}{{ ep }}{% if not loop.last %}, {% endif %}{% endfor %}]
{% if s.tls | default(true) %}
{% if (s.tls_cert_resolver | default(traefik_acme_resolver_name) | string | length) > 0 %}
      tls: { certResolver: {{ s.tls_cert_resolver | default(traefik_acme_resolver_name) }} }
{% else %}
      tls: {}
{% endif %}
{% endif %}
{% endfor %}
{% else %}
{% for c in _certs %}
{% set _cn = (c.cert_name | default(c.domains | first)) %}
{% set _name = (_cn | regex_replace('[^a-zA-Z0-9_-]', '-') | lower) %}
    site-{{ _name }}:
      rule: "{% for d in (c.domains | default([])) %}Host(`{{ d }}`){% if not loop.last %} || {% endif %}{% endfor %}"
      service: svc-{{ _name }}
      entryPoints: [websecure]
      tls: {}
{% endfor %}
{% endif %}

  services:
{% if _sites | length > 0 %}
{% for s in _sites %}
    svc-{{ (s.name | default('site-' ~ loop.index)) | regex_replace('[^a-zA-Z0-9_-]', '-') | lower }}:
      loadBalancer:
        servers:
{% for u in (s.upstream_servers | default([])) %}
          - { url: "{{ u }}" }
{% endfor %}
        passHostHeader: true
{% endfor %}
{% else %}
{% for c in _certs %}
{% set _cn = (c.cert_name | default(c.domains | first)) %}
{% set _name = (_cn | regex_replace('[^a-zA-Z0-9_-]', '-') | lower) %}
    svc-{{ _name }}:
      loadBalancer:
        servers:
{% for h in _backend_hosts %}
          - { url: "http://{{ hostvars[h].ansible_host | default(h) }}:{{ traefik_generated_upstream_port | default(4000) }}" }
{% endfor %}
        passHostHeader: true
{% endfor %}
{% endif %}
{% endif %}
