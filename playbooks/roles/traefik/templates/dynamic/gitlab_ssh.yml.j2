tcp:
  routers:
    gitlab-ssh:
      entryPoints: [gitlab-ssh]
      # SSH is plain TCP (no TLS/SNI). HostSNI(`*`) acts as catch-all.
      rule: "HostSNI(`*`)"
      service: gitlab-ssh-svc

  services:
    gitlab-ssh-svc:
      loadBalancer:
        servers:
          - address: "{{ traefik_gitlab_ssh_upstream_host }}:{{ traefik_gitlab_ssh_upstream_port }}"
