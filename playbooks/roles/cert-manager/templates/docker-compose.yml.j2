version: "3.8"

services:
  certbot:
    image: certbot/certbot:latest
    entrypoint:
      - /bin/sh
      - -ec
    command: |
        umask 077
        echo "cert-manager: initial obtain/renew (webroot)"
        certbot certonly --webroot \
          -w /var/www/certbot \
          {% for d in cert_manager_domains | default([app_domain_name]) %}-d {{ d }} {% endfor %} \
          --email "{{ cert_manager_email }}" \
          --agree-tos \
          --non-interactive \
          --keep-until-expiring
        echo "cert-manager: enter renew loop"
        while true; do
          certbot renew --webroot -w /var/www/certbot --quiet || true
          sleep 12h
        done
    volumes:
      - "{{ gluster_mount_path }}/{{ cert_manager_gfs_subdir }}/{{ cert_manager_letsencrypt_subdir }}:/etc/letsencrypt"
      - "{{ gluster_mount_path }}/{{ cert_manager_gfs_subdir }}/{{ cert_manager_webroot_subdir }}:/var/www/certbot"

  certbot-web:
    image: nginx:alpine
    command:
      - /bin/sh
      - -ec
      - |
        cat > /etc/nginx/conf.d/default.conf <<'EOF'
        server {
          listen 80;
          server_name _;
          location /.well-known/acme-challenge/ {
            root /var/www/certbot;
            default_type "text/plain";
            try_files $$uri =404;
          }
          location = /.well-known/acme-challenge/healthz {
            return 200 "ok\n";
          }
          location / {
            return 404;
          }
        }
        EOF
        nginx -g 'daemon off;'
    volumes:
      - "{{ gluster_mount_path }}/{{ cert_manager_gfs_subdir }}/{{ cert_manager_webroot_subdir }}:/var/www/certbot:ro"
{% if cert_manager_publish_http | default(false) %}
    ports:
      - "{{ cert_manager_compose_bind_ip | default('127.0.0.1') }}:{{ cert_manager_publish_http_port | default(8088) }}:80"
{% endif %}
