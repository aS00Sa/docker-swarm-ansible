NFS_CORE_PARAM {
  Enable_NLM = false;
  Enable_RQUOTA = false;
  Protocols = 4;
}

EXPORT {
  Export_Id = {{ gluster_ganesha_export_id }};
  Path = {{ gluster_ganesha_export_path }};
  Pseudo = {{ gluster_ganesha_export_pseudo }};
  Access_Type = RW;
  Squash = No_root_squash;
  Protocols = 4;
  Transports = TCP;
  SecType = sys;
  FSAL {
    Name = VFS;
  }

  # Allow only edge nodes (haproxy/traefik) as NFS clients.
  CLIENT {
    Clients = {{ edge_nfs_client_ips | join(",") }};
    Access_Type = RW;
    Squash = No_root_squash;
  }
}

