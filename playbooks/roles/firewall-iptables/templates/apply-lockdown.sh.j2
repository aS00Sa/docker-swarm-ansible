#!/bin/bash
set -euo pipefail
# Управляемые цепочки: снимаем старый jump, пересоздаём правила (идемпотентно по смыслу).

while iptables -D INPUT -j SWARM-INPUT 2>/dev/null; do :; done
while iptables -D DOCKER-USER -j SWARM-FORWARD 2>/dev/null; do :; done
iptables -F SWARM-INPUT 2>/dev/null || true
iptables -F SWARM-FORWARD 2>/dev/null || true
iptables -X SWARM-INPUT 2>/dev/null || true
iptables -X SWARM-FORWARD 2>/dev/null || true

iptables -N SWARM-INPUT
iptables -N SWARM-FORWARD

# --- INPUT: трафик на сам хост (SSH, ping, HTTP(S) к процессам на хосте) ---
iptables -A SWARM-INPUT -i lo -j RETURN
iptables -A SWARM-INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j RETURN
{% for ip in firewall_cluster_ips | unique %}
iptables -A SWARM-INPUT -s {{ ip }} -j RETURN
{% endfor %}
{% if firewall_allow_ssh_world | bool %}
iptables -A SWARM-INPUT -p tcp --dport {{ firewall_ssh_port }} -j RETURN
{% else %}
{% for cidr in firewall_ssh_allow_sources %}
iptables -A SWARM-INPUT -s {{ cidr }} -p tcp --dport {{ firewall_ssh_port }} -j RETURN
{% endfor %}
{% endif %}
iptables -A SWARM-INPUT -p tcp -m multiport --dports {{ firewall_public_tcp_merged | join(',') }} -j RETURN
{% if keepalived_enabled | default(false) | bool %}
iptables -A SWARM-INPUT -p 112 -j RETURN
{% endif %}
iptables -A SWARM-INPUT -p icmp -j RETURN
iptables -A SWARM-INPUT -m conntrack --ctstate INVALID -j DROP
iptables -A SWARM-INPUT -j DROP

# --- DOCKER-USER: FORWARD к контейнерам / ingress mesh (раньше DOCKER-INGRESS) ---
# RETURN — отдать обратно в DOCKER-USER, дальше Docker (в т.ч. DOCKER-INGRESS с 9000/8000).
# С интернета только разрешённые TCP-порты; с нод кластера — всё (Swarm + Gluster + Portainer по внутренним IP).
iptables -A SWARM-FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j RETURN
{% for ip in firewall_cluster_ips | unique %}
iptables -A SWARM-FORWARD -s {{ ip }} -j RETURN
{% endfor %}
# SSH идёт в INPUT, не в DOCKER-USER; здесь только доступ к опубликованным портам сервисов.
iptables -A SWARM-FORWARD -p tcp -m multiport --dports {{ firewall_public_tcp_merged | join(',') }} -j RETURN
iptables -A SWARM-FORWARD -m conntrack --ctstate INVALID -j DROP
iptables -A SWARM-FORWARD -j DROP

iptables -I INPUT 1 -j SWARM-INPUT
iptables -I DOCKER-USER 1 -j SWARM-FORWARD
