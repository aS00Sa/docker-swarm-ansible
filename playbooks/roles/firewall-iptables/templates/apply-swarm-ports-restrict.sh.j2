#!/bin/bash
set -euo pipefail
# INPUT: служебные порты Docker Swarm — только с IP нод кластера и admin CIDR; с остальных DROP.
# Цепочка SWARM-NODE-PORTS. Portainer — отдельный шаблон apply-portainer-ports-restrict.sh.j2.

{% set _tcp_blocked = firewall_restrict_swarm_tcp_dports | default([2377, 7946]) | map('int') | list | unique | sort %}
{% set _udp_blocked = firewall_restrict_swarm_udp_dports | default([7946, 4789]) | map('int') | list | unique | sort %}

while iptables -D INPUT -j SWARM-NODE-PORTS 2>/dev/null; do :; done
iptables -F SWARM-NODE-PORTS 2>/dev/null || true
iptables -X SWARM-NODE-PORTS 2>/dev/null || true

iptables -N SWARM-NODE-PORTS

iptables -A SWARM-NODE-PORTS -i lo -j RETURN
iptables -A SWARM-NODE-PORTS -m conntrack --ctstate RELATED,ESTABLISHED -j RETURN
{% for ip in firewall_cluster_ips | unique %}
iptables -A SWARM-NODE-PORTS -s {{ ip }} -j RETURN
{% endfor %}
{% for cidr in firewall_effective_admin_cidrs | unique %}
iptables -A SWARM-NODE-PORTS -s {{ cidr }} -j RETURN
{% endfor %}
{% if _tcp_blocked | length > 0 %}
iptables -A SWARM-NODE-PORTS -p tcp -m multiport --dports {{ _tcp_blocked | join(',') }} -j DROP
{% endif %}
{% if _udp_blocked | length > 0 %}
iptables -A SWARM-NODE-PORTS -p udp -m multiport --dports {{ _udp_blocked | join(',') }} -j DROP
{% endif %}
iptables -A SWARM-NODE-PORTS -j RETURN

iptables -I INPUT 1 -j SWARM-NODE-PORTS
