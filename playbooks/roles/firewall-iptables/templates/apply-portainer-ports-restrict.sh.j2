#!/bin/bash
set -euo pipefail
# INPUT: опубликованные служебные TCP Portainer (tunnel, agent) — только с IP нод кластера и admin CIDR; с остальных DROP.
# Цепочка PORTAINER-NODE-PORTS. Swarm — apply-swarm-ports-restrict.sh.j2.

{% set _tcp_blocked = firewall_restrict_portainer_tcp_dports | default([8000, 9001]) | map('int') | list | unique | sort %}

while iptables -D INPUT -j PORTAINER-NODE-PORTS 2>/dev/null; do :; done
iptables -F PORTAINER-NODE-PORTS 2>/dev/null || true
iptables -X PORTAINER-NODE-PORTS 2>/dev/null || true

iptables -N PORTAINER-NODE-PORTS

iptables -A PORTAINER-NODE-PORTS -i lo -j RETURN
iptables -A PORTAINER-NODE-PORTS -m conntrack --ctstate RELATED,ESTABLISHED -j RETURN
{% for ip in firewall_cluster_ips | unique %}
iptables -A PORTAINER-NODE-PORTS -s {{ ip }} -j RETURN
{% endfor %}
{% for cidr in firewall_effective_admin_cidrs | unique %}
iptables -A PORTAINER-NODE-PORTS -s {{ cidr }} -j RETURN
{% endfor %}
{% if _tcp_blocked | length > 0 %}
iptables -A PORTAINER-NODE-PORTS -p tcp -m multiport --dports {{ _tcp_blocked | join(',') }} -j DROP
{% endif %}
iptables -A PORTAINER-NODE-PORTS -j RETURN

iptables -I INPUT 1 -j PORTAINER-NODE-PORTS
